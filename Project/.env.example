# Required: the model endpoint used by src/agent/common/llm.py
PACKYAPI_API_KEY=replace_me
PACKYAPI_BASE_URL=https://your-openai-compatible-endpoint/v1
PACKYAPI_MODEL=gpt-5.4

# Required by a self-hosted LangGraph Agent Server image.
# Obtain these from LangSmith/LangGraph if you use `docker compose` deployment.
LANGSMITH_API_KEY=replace_me
LANGGRAPH_CLOUD_LICENSE_KEY=replace_me

# Change before exposing Compose outside your computer.
POSTGRES_PASSWORD=langgraph-local-only

# These are build-time frontend values. `/api` is proxied by the production
# frontend container; set an absolute URL only when deploying it separately.
VITE_API_BASE_URL=/api
VITE_ASSISTANT_ID=agent
