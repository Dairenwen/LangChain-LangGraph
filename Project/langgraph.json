{
  "$schema": "https://langgra.ph/schema.json",
  "dependencies": ["."],
  "graphs": {
    "agent": "./src/agent/graph.py:graph",
    "recommend_graph": "./src/agent/recommend.py:recommend_graph",
    "reserve_graph": "./src/agent/reserve.py:reserve_graph",
    "extend_graph": "./src/agent/node/extend.py:extend_graph"
  },
  "env": ".env",
  "image_distro": "wolfi",
  "checkpointer": {
    "backend": "default"
  },
  "http": {
    "cors": {
      "allow_origins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173"
      ],
      "allow_methods": ["*"],
      "allow_headers": ["*"]
    }
  }
}
